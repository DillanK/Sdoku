### 관련 코드 스니펫
**`Persistence.swift` — CoreData 스택 (핵심 진입점)**
struct PersistenceController {
    static let shared = PersistenceController()

    @MainActor
    static let preview: PersistenceController = {
        let result = PersistenceController(inMemory: true)
        // ... seed data ...
        return result
    }()

    let container: NSPersistentContainer

    init(inMemory: Bool = false) {
        container = NSPersistentContainer(name: "Sdoku")
        if inMemory {
            container.persistentStoreDescriptions.first!.url = URL(fileURLWithPath: "/dev/null")
        }
        container.loadPersistentStores { ... }
        container.viewContext.automaticallyMergesChangesFromParent = true
    }
}

**`SdokuApp.swift` — 환경값 주입 방식**
@main
struct SdokuApp: App {
    let persistenceController = PersistenceController.shared

    var body: some Scene {
        WindowGroup {
            ContentView()
                .environment(\.managedObjectContext, persistenceController.container.viewContext)
        }
    }
}

**`Sdoku.xcdatamodel/contents` — 현재 모델 상태**
<entity name="Item" representedClassName="Item" syncable="YES" codeGenerationType="class">
    <attribute name="timestamp" optional="YES" attributeType="Date" usesScalarValueType="NO"/>
</entity>
> `GameRecord` 엔티티 추가 필요. `Item` 엔티티는 `ContentView` 교체와 함께 제거 가능.

**`SdokuTests/SdokuTests.swift` — 테스트 프레임워크**
import Testing
@testable import Sdoku

struct SdokuTests {
    @Test func example() async throws { }
}
> `GameRecordRepositoryTests`는 동일 `Testing` 프레임워크 또는 `XCTest` 중 선택 필요.  
> `PersistenceController(inMemory: true)`로 인메모리 컨텍스트를 생성해 테스트해야 함.

