### 핵심 의존 관계
GameView
  └── @State GameViewModel
        ├── SudokuGridView(@State viewModel)  ──→  selectCell(row:col:)
        │     └── SudokuCellView(cell, isSelected, isRelated)
        │           └── NoteGridView(notes)   [private]
        ├── GameControlsView(@Bindable viewModel)
        └── NumberPadView(@Bindable viewModel)
              ├── viewModel.inputNumber(_:)
              └── viewModel.clearCell()

GameViewModel (@Observable)
  ├── board: SudokuBoard        → cells[row][col]: SudokuCell
  ├── selectedRow: Int?
  ├── selectedCol: Int?
  ├── isPencilMode: Bool
  └── canUndo: Bool

SudokuCell
  ├── value: Int       (0 = 빈칸)
  ├── isFixed: Bool
  ├── notes: Set<Int>
  └── isConflict: Bool

